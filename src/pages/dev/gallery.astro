---
// THROWAWAY component gallery (Step 5). Delete the /dev folder before launch.
import Base from '../../layouts/Base.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import Section from '../../components/ui/Section.astro';
import Pill from '../../components/ui/Pill.astro';
import PullQuote from '../../components/ui/PullQuote.astro';
import CtaBand from '../../components/ui/CtaBand.astro';
import StepList from '../../components/ui/StepList.astro';
import TextField from '../../components/ui/TextField.astro';
import TextArea from '../../components/ui/TextArea.astro';
import Select from '../../components/ui/Select.astro';
import FormStatus from '../../components/ui/FormStatus.astro';

const steps = [
  { title: 'Enquiry and scoping', body: 'We confirm requirements, timelines, and compliance needs.' },
  { title: 'Proposal and pricing', body: 'A clear, itemised proposal mapped to your procurement process.' },
  { title: 'Delivery', body: 'Sourcing, logistics, and installation managed end to end.' },
  { title: 'Handover and support', body: 'Documentation, training, and after-delivery support.' },
];

const sectors = ['State government MDAs', 'Federal agencies', 'Health', 'Education', 'Oil & gas', 'Development finance'];
---

<Base title="Component gallery — Northaxis (dev only)">
  <Section width="wide" space="md">
    <p class="text-sm font-medium tracking-wide text-grey uppercase">Dev only — delete before launch</p>
    <h1 class="mt-2 text-3xl font-bold text-ink">Component gallery</h1>
    <p class="mt-2 text-grey">Hover and focus (Tab) each control to check transitions and focus rings.</p>

    <!-- Buttons -->
    <h2 class="mt-12 mb-4 text-xl font-bold text-ink">Buttons</h2>
    <div class="flex flex-wrap items-center gap-3">
      <Button variant="primary">Primary</Button>
      <Button variant="secondary">Secondary</Button>
      <Button variant="ghost">Ghost</Button>
      <Button variant="primary" arrow>With arrow</Button>
      <Button variant="primary" disabled>Disabled</Button>
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-3">
      <Button variant="primary" size="sm">Small</Button>
      <Button variant="primary" size="md">Medium</Button>
      <Button variant="primary" size="lg">Large</Button>
      <Button variant="secondary" href="/dev/tokens">Link button</Button>
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-3 rounded-lg p-4" style="background:var(--color-ink)">
      <Button variant="primary" onDark>On dark primary</Button>
      <Button variant="secondary" onDark>On dark secondary</Button>
      <Button variant="primary" onDark arrow>With arrow</Button>
    </div>

    <!-- Cards -->
    <h2 class="mt-12 mb-4 text-xl font-bold text-ink">Cards</h2>
    <div class="grid gap-4 sm:grid-cols-3">
      <Card>
        <h3 class="nx-card__title">Default card</h3>
        <p class="nx-card__body">A bordered container for grouped content.</p>
      </Card>
      <Card href="/dev/tokens" hover>
        <h3 class="nx-card__title">Link card (hover)</h3>
        <p class="nx-card__body">The whole card is a link with a hover lift.</p>
      </Card>
      <Card variant="consultancy">
        <h3 class="nx-card__title">Consultancy</h3>
        <p class="nx-card__body">Light-teal register signals the cross-cutting advisory layer.</p>
      </Card>
    </div>

    <!-- Pills -->
    <h2 class="mt-12 mb-4 text-xl font-bold text-ink">Pills / tags</h2>
    <div class="flex flex-wrap gap-2">
      {sectors.map((s) => <Pill>{s}</Pill>)}
      <Pill variant="teal">Consultancy</Pill>
    </div>

    <!-- PullQuote -->
    <h2 class="mt-12 mb-4 text-xl font-bold text-ink">Pull quote (serif, consultancy)</h2>
    <PullQuote cite="Northaxis advisory">
      We help public-sector teams turn procurement intent into delivered infrastructure, one
      integrated solution at a time.
    </PullQuote>

    <!-- StepList -->
    <h2 class="mt-12 mb-4 text-xl font-bold text-ink">Step list</h2>
    <StepList steps={steps} class="max-w-2xl" />

    <!-- Form fields -->
    <h2 class="mt-12 mb-4 text-xl font-bold text-ink">Form fields</h2>
    <form class="grid max-w-xl gap-5" onsubmit="return false">
      <TextField label="Full name" name="name" required placeholder="Jane Doe" autocomplete="name" />
      <TextField label="Work email" name="email" type="email" hint="We reply within two working days." placeholder="jane@ministry.gov.ng" />
      <TextField label="Phone" name="phone" type="tel" error="Enter a valid phone number." value="abc" />
      <Select label="Service of interest" name="service" placeholder="Choose a service" required
        options={[
          { value: 'procurement', label: 'Procurement, supply chain & logistics' },
          { value: 'ict', label: 'ICT services' },
          { value: 'energy', label: 'Energy & sustainability' },
          { value: 'consultancy', label: 'Consultancy' },
        ]} />
      <TextArea label="Message" name="message" placeholder="Tell us about your requirement" hint="Optional." />
      <TextField label="Disabled field" name="disabled" disabled value="Not editable" />
    </form>

    <!-- FormStatus -->
    <h2 class="mt-12 mb-4 text-xl font-bold text-ink">Form status</h2>
    <div class="grid max-w-xl gap-3">
      <FormStatus type="success">Thank you. Your enquiry has been sent and we will be in touch shortly.</FormStatus>
      <FormStatus type="error">Something went wrong sending your enquiry. Please try again or use WhatsApp.</FormStatus>
    </div>

    <!-- CtaBand -->
    <h2 class="mt-12 mb-4 text-xl font-bold text-ink">CTA band</h2>
    <CtaBand title="Start a conversation with Northaxis" sub="Tell us what you need and we will map it to a clear delivery plan." variant="teal">
      <Button variant="primary" onDark href="/contact" arrow>Get in touch</Button>
      <Button variant="secondary" onDark href="/what-we-do">View our services</Button>
    </CtaBand>
    <div class="mt-4">
      <CtaBand title="Download our capability statement" variant="ink">
        <Button variant="primary" onDark arrow>Download PDF</Button>
      </CtaBand>
    </div>
  </Section>
</Base>
