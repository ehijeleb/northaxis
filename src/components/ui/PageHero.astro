---
// PageHero — shared dark hero with breadcrumb, headline, sub, and an actions slot.
// Used by service pages, the consultancy page, and other interior pages. Background is a deep-ink
// brand PLACEHOLDER (swap for real photography later; fixed min-height keeps CLS at zero).
import Breadcrumb from './Breadcrumb.astro';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
  headline: string;
  sub?: string;
  titleId?: string;
  class?: string;
}
const { crumbs, headline, sub, titleId = 'page-hero-title', class: className } = Astro.props;
---

<section class:list={['nx-phero', className]} aria-labelledby={titleId}>
  <div class="nx-phero__bg" aria-hidden="true"></div>
  <div class="nx-phero__inner">
    <Breadcrumb items={crumbs} class="nx-phero__crumb" />
    <h1 id={titleId} class="nx-phero__title">{headline}</h1>
    {sub && <p class="nx-phero__sub">{sub}</p>}
    <div class="nx-phero__actions"><slot /></div>
  </div>
</section>

<style>
  .nx-phero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    min-height: clamp(20rem, 42vh, 26rem);
  }
  .nx-phero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-color: #14201d;
    background-image: linear-gradient(180deg, rgba(15, 110, 86, 0.18) 0%, rgba(20, 32, 29, 0) 45%),
      linear-gradient(0deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0) 60%);
  }
  .nx-phero__inner {
    width: 100%;
    max-width: 72rem;
    margin-inline: auto;
    padding: 2.5rem 1.25rem;
    color: #fff;
  }
  @media (min-width: 640px) {
    .nx-phero__inner {
      padding: 3rem 1.5rem;
    }
  }
  .nx-phero__crumb {
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 1rem;
  }
  .nx-phero__title {
    margin: 0;
    max-width: 24ch;
    font-size: clamp(1.8rem, 1.1rem + 3vw, 2.9rem);
    font-weight: 700;
    line-height: 1.1;
  }
  .nx-phero__sub {
    margin: 1.1rem 0 0;
    max-width: 60ch;
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.12rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.88);
  }
  .nx-phero__actions {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }
  .nx-phero__actions:empty {
    display: none;
  }
</style>
