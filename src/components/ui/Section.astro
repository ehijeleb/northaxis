---
// Section — consistent section wrapper: background, vertical rhythm, centered max-width container.
interface Props {
  as?: string;
  /** Background fill. */
  bg?: 'default' | 'white' | 'tealLight' | 'ink';
  /** Inner content max width. */
  width?: 'narrow' | 'default' | 'wide';
  /** Vertical padding scale. */
  space?: 'sm' | 'md' | 'lg';
  class?: string;
  id?: string;
}

const { as = 'section', bg = 'default', width = 'default', space = 'lg', class: className, id } = Astro.props;
const Tag = as as any;

const bgStyle = {
  default: 'background:var(--color-bg)',
  white: 'background:#fff',
  tealLight: 'background:var(--color-teal-light)',
  ink: 'background:var(--color-ink);color:#fff',
}[bg];

const widthClass = {
  narrow: 'max-w-3xl',
  default: 'max-w-6xl',
  wide: 'max-w-7xl',
}[width];

const spaceClass = {
  sm: 'py-10 md:py-12',
  md: 'py-14 md:py-20',
  lg: 'py-16 md:py-24',
}[space];
---

<Tag id={id} class:list={[spaceClass, className]} style={bgStyle}>
  <div class:list={['mx-auto px-5 sm:px-6', widthClass]}>
    <slot />
  </div>
</Tag>
