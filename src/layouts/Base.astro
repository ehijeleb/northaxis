---
// Base layout — html shell, self-hosted fonts, skip-link, meta slots.
// Global furniture (Header/Footer/WhatsApp/cookie banner) is added in Phase B (Steps 3–4).

// Self-host fonts (no render-blocking Google Fonts request).
import '@fontsource-variable/inter';
import '@fontsource/source-serif-4'; // serif, consultancy contexts only
import '../styles/tokens.css';
import '../styles/primitives.css';
import '../styles/consent.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import CookieConsent from '../components/CookieConsent.tsx';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Northaxis Integrated Services',
  description = 'Northaxis Integrated Services — integrated procurement, ICT, energy, and advisory for the public sector in Edo State and across Nigeria.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Per-page extra head content (canonical, OG, JSON-LD) goes here from Step 20. */}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    {/* Global header (Logo + interactive Nav). A page can override with the "header" slot. */}
    <slot name="header"><Header /></slot>

    <main id="main">
      <slot />
    </main>

    {/* Global footer (overridable via the "footer" slot). */}
    <slot name="footer"><Footer /></slot>

    {/* Global furniture: floating WhatsApp + privacy-first cookie consent. */}
    <WhatsAppButton />
    <CookieConsent client:idle />
  </body>
</html>
